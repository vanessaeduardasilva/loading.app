# Copie esse arquivo pra .env e preencha com sua chave
# Nunca commite o .env no git!

ANTHROPIC_API_KEY=sk-ant-coloque-sua-chave-aqui

# Quantas mensagens por IP por minuto (padrão: 15)
RATE_LIMIT_PER_MINUTE=15

# development = modo debug | production = modo produção
FLASK_ENV=development

# Porta (Railway e Render definem isso automaticamente)
PORT=5000
